# .env.example — Copy this file to .env and fill in your real credentials
# IMPORTANT: Never commit .env to version control

# ---------------------------------------------------------------------------
# Core Configuration
# ---------------------------------------------------------------------------

# LLM provider selection: "gemini" | "huggingface" | "openai" | "anthropic" | "mock"
LLM_PROVIDER=gemini

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) OpenAI API Key — only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Anthropic API Key — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
